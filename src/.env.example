APP_NAME="トレーニング記録管理システム"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=ja
APP_FALLBACK_LOCALE=ja
APP_FAKER_LOCALE=ja_JP
APP_TIMEZONE=Asia/Tokyo

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DAILY_DAYS=30
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=training_record
DB_USERNAME=laravel
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=15
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
# log ドライバ使用時、メール本文を専用ファイル(storage/logs/mail.log)へ出すための専用チャンネル。
# アプリ全体の LOG_LEVEL=info でもメール(debug)を捕捉できるよう logging.php の 'mail' は level=debug 固定。
MAIL_LOG_CHANNEL=mail
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# 外部API（音声文字起こし・要約）
OPENAI_API_KEY=
OPENAI_ORGANIZATION=
OPENAI_REQUEST_TIMEOUT=300
ANTHROPIC_API_KEY=
# 要約に使う Anthropic モデル。未設定時は config のデフォルト claude-sonnet-4-6 を使用。
# モデル引退時はこの値を有効なモデル文字列に変更する（例: claude-sonnet-5）。
ANTHROPIC_MODEL=claude-sonnet-4-6

VITE_APP_NAME="${APP_NAME}"

# Backup
BACKUP_DIRECTORY=C:/Users/y-ouchi/workspace/dev/training-record-system/src/storage/app/backups
BACKUP_ENCRYPTION_KEY=
MYSQLDUMP_PATH="C:/Program Files/MySQL/MySQL Workbench 8.0/mysqldump.exe"
MYSQL_PATH="C:/Program Files/MySQL/MySQL Workbench 8.0/mysql.exe"
OPENSSL_PATH="C:/Program Files/Git/mingw64/bin/openssl.exe"

# Restore (Cloudflare R2)
R2_ENDPOINT=https://7e2d676e31f746acd5bcc20fd6333e6c.r2.cloudflarestorage.com
R2_BUCKET=training-record-backup-dev
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Media File Storage
SAKURA_ENDPOINT=https://s3.tky01.sakurastorage.jp
SAKURA_BUCKET=trs-media-dev
SAKURA_DEFAULT_REGION=jp-east-1
SAKURA_ACCESS_KEY_ID=
SAKURA_SECRET_ACCESS_KEY=

# Media conversion (ImageMagick)
# 表示用変換（heic→jpeg 等）で呼び出す magick コマンドのパス。
# Linux 本番 : 未設定でよい（PATH 上の 'magick' を解決）
# Windows 開発: 開発サーバー（Herd / php -S）の子プロセスは PATH 解決に失敗するため、フルパスで指定する
# MAGICK_PATH="C:/Program Files/ImageMagick-7.1.2-Q16-HDRI/magick.exe"
MAGICK_PATH=

# Media conversion (FFmpeg)
# 表示用変換（mov→mp4 等）で呼び出す ffmpeg コマンドのパス。
# Linux 本番 : 未設定でよい（PATH 上の 'ffmpeg' を解決）
# Windows 開発: 開発サーバー（Herd / php -S）の子プロセスは PATH 解決に失敗するため、フルパスで指定する
# FFMPEG_PATH="C:/ffmpeg/bin/ffmpeg.exe"
FFMPEG_PATH=